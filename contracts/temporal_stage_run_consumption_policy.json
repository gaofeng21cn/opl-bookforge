  "consumed_opl_refs": [
    "stage_run_ref",
    "temporal_workflow_ref",
    "provider_attempt_ref",
    "attempt_ledger_ref",
    "stage_manifest_ref",
    "stage_current_pointer_ref",
    "owner_receipt_ref",
    "typed_blocker_ref",
    "human_gate_ref",
    "route_back_ref"
  ],
  "bookforge_owned_refs": [
    "book_truth_ref",
    "manuscript_quality_ref",
    "style_policy_ref",
    "export_publication_verdict_ref",
    "artifact_authority_ref",
    "memory_body_ref",
    "owner_receipt_body_ref",
    "minimal_book_native_authority_function_ref"
  ],
  "bookforge_exposed_domain_surfaces": [
    "book_domain_action_contract_ref",
    "chapter_task_card_ref",
    "manuscript_authority_ref",
    "style_authority_ref",
    "artifact_authority_ref",
    "owner_gated_publication_decision_ref",
    "owner_gated_export_decision_ref",
    "typed_blocker_ref",
    "owner_receipt_ref"
  ],
  "forbidden_runtime_surface_exports": [
    "private_temporal_wrapper",
    "private_stage_run_wrapper",
    "private_scheduler",
    "private_queue",
    "private_session_store",
    "private_provider_completion_store",
    "private_attempt_ledger",
    "runtime_status_read_model"
  ],
  "completion_boundary": {
    "provider_completion_is_domain_completion": false,
    "provider_completion_is_closeout": false,
    "provider_completion_can_claim_domain_ready": false,
    "temporal_workflow_completion_counts_as_domain_ready": false,
    "stage_run_status_ready_counts_as_domain_ready": false,
    "generated_surface_ready_counts_as_domain_ready": false,
    "generated_surface_ready_can_claim_quality_or_export": false,
    "read_model_counts_as_transition_authority": false,
    "file_presence_counts_as_stage_complete": false,
    "domain_completion_ref_fields": [
      "owner_receipt_ref",
      "typed_blocker_ref",
      "human_gate_ref",
      "route_back_ref"
    ],
    "domain_completion_requires_one_of_ref_fields": true
  },
  "completion_audit": {
    "audit_id": "bookforge_owner_export_completion_audit",
    "audit_role": "separate_opl_transport_generated_status_from_bookforge_domain_completion",
    "opl_provider_generated_and_stage_run_accounts": {
      "provider_attempt_completion": {
        "owner": "one-person-lab",
        "counts_as_bookforge_domain_completion": false,
        "counts_as_review_pdf_ready": false,
        "counts_as_publication_proof_ready": false,
        "counts_as_final_export_ready": false,
        "counts_as_owner_acceptance": false
      },
      "generated_surface_ready": {
        "owner": "one-person-lab",
        "counts_as_bookforge_domain_completion": false,
        "counts_as_review_pdf_ready": false,
        "counts_as_publication_proof_ready": false,
        "counts_as_final_export_ready": false,
        "counts_as_owner_acceptance": false
      },
      "stage_run_status_ready": {
        "owner": "one-person-lab",
        "counts_as_bookforge_domain_completion": false,
        "counts_as_review_pdf_ready": false,
        "counts_as_publication_proof_ready": false,
        "counts_as_final_export_ready": false,
        "counts_as_owner_acceptance": false
      }
    },
    "bookforge_completion_accounts": {
      "review_pdf": {
        "owner": "OPL Book Forge",
        "minimum_ref_fields": [
          "review_pdf_ref",
          "review_pdf_receipt_ref"
        ],
        "requires_owner_acceptance": false,
        "counts_as_publication_proof_ready": false,
        "counts_as_final_export_ready": false,
        "counts_as_owner_acceptance": false
      },
      "publication_proof": {
        "owner": "OPL Book Forge",
        "minimum_ref_fields": [
          "publication_proof_ref",
          "publication_design_profile_ref",
          "rendered_page_inspection_ref",
          "asset_resolution_receipt_ref"
        ],
        "requires_owner_acceptance": false,
        "counts_as_final_export_ready": false,
        "counts_as_owner_acceptance": false
      },
      "final_export": {
        "owner": "OPL Book Forge",
        "minimum_ref_fields": [
          "final_export_ref",
          "publication_proof_ref",
          "owner_export_acceptance_ref"
        ],
        "requires_owner_export_acceptance": true,
        "counts_as_owner_acceptance": false
      },
      "owner_acceptance": {
        "owner": "owner_or_human_gate",
        "minimum_ref_fields": [
          "owner_receipt_ref"
        ],
        "can_be_written_by_opl_provider": false,
        "can_be_written_by_generated_surface": false,
        "can_be_inferred_from_stage_run_status": false
      }
    },
    "acceptance_tail": {
      "real_book_pilot_evidence_role": "historical_evidence_only",
      "real_book_pilot_counts_as_final_export_acceptance": false,
      "owner_receipt_body_must_not_be_synthesized_by_contract": true,
      "live_stage_run_evidence_required_for_runtime_claims": true,
      "owner_export_acceptance_required_for_final_export_claims": true,
      "missing_owner_export_acceptance_routes_to": "owner_or_human_gate",
      "missing_live_stage_run_evidence_routes_to": "one-person-lab"
    }
  },
  "functional_closure_gate": {
    "gate_id": "bookforge_non_live_functional_closure_gate",
    "gate_role": "non_live_structural_closure_for_standard_default_path",
    "state": "functional_structure_gate_landed_not_publication_or_owner_acceptance",
    "required_non_live_gate_refs": [
      {
        "gate": "standard_scaffold_interface",
        "contract_ref": "contracts/domain_descriptor.json",
        "validator_refs": [
          "opl agents scaffold --validate <repo-dir> --json",
          "opl agents interfaces --repo-dir <repo-dir> --json"
        ],
        "claim_boundary": "scaffold_and_interface_validation_only"
      },
      {
        "gate": "golden_path_default_route",
        "contract_ref": "contracts/golden_path_profile.json",
        "claim_boundary": "storyline_architecture_default_route_only"
      },
      {
        "gate": "revision_entrypoint_route",
        "contract_ref": "agent/skills/revision-entrypoint-router.md",
        "support_ref": "docs/references/opl-base-revision-routing-handoff.md",
        "claim_boundary": "route_back_structure_only"
      },
      {
        "gate": "pdf_proof_helper_plumbing",
        "contract_ref": "runtime/native_helpers/bookforge_pdf_export.py",
        "validator_refs": [
          "runtime/native_helpers/bookforge_pdf_export.py --doctor",
          "scripts/verify.sh"
        ],
        "claim_boundary": "helper_plumbing_only_not_visual_acceptance"
      },
      {
        "gate": "artifact_lifecycle_handoff",
        "contract_ref": "contracts/artifact_lifecycle_handoff.json",
        "claim_boundary": "handoff_refs_only_not_workspace_apply_evidence"
      },
      {
        "gate": "default_caller_structural_gate",
        "contract_ref": "contracts/functional_privatization_audit.json",
        "claim_boundary": "structural_delete_gate_only_not_physical_delete_authorization"
      },
      {
        "gate": "evidence_package_navigation",
        "contract_ref": "docs/evidence/README.md",
        "claim_boundary": "historical_evidence_index_only_not_active_truth"
      }
    ],
    "default_path_assertions": {
      "default_cli_app_skill_path_must_route_via_opl_generated_or_hosted_surfaces": true,
      "stage_run_and_generated_surface_status_are_transport_or_projection_only": true,
      "bookforge_owner_answer_shape_required_for_domain_completion": true,
      "owner_answer_shapes": [
        "owner_receipt_ref",
        "typed_blocker_ref",
        "human_gate_ref",
        "route_back_ref"
      ],
      "no_private_runtime_wrapper_or_default_caller_second_truth": true
    },
    "later_evidence_lanes": [
      "real_long_book_run_evidence",
      "publication_proof_visual_acceptance",
      "final_export_owner_acceptance",
      "direct_runtime_cli_or_hosted_artifact_handoff_parity",
      "workspace_artifact_lifecycle_apply_receipt",
      "physical_delete_authorization"
    ],
    "forbidden_claims": {
      "functional_closure_gate_can_claim_publication_ready": false,
      "functional_closure_gate_can_claim_final_export_ready": false,
      "functional_closure_gate_can_claim_owner_acceptance": false,
      "functional_closure_gate_can_claim_domain_ready": false,
      "functional_closure_gate_can_claim_production_ready": false,
      "functional_closure_gate_can_authorize_physical_delete": false
    }
  },
  "forbidden_domain_repo_ownership": {
    "domain_repo_can_own_temporal_runtime": false,
    "domain_repo_can_own_temporal_queue": false,
    "domain_repo_can_own_provider_completion": false,
    "domain_repo_can_own_provider_attempts": false,
    "domain_repo_can_own_stage_run_state_machine": false,
    "domain_repo_can_own_temporal_wrapper": false,
    "domain_repo_can_own_stage_run_wrapper": false,
    "domain_repo_can_own_attempt_ledger": false,
    "domain_repo_can_own_generic_scheduler": false,
    "domain_repo_can_own_session_store": false,
    "domain_repo_can_own_generated_status_surface": false,
    "domain_repo_can_create_private_temporal_runtime": false,
    "domain_repo_can_create_private_stage_attempt_ledger": false
  },
  "write_boundary": {
    "bookforge_can_write_opl_stage_attempts": false,
    "bookforge_can_write_temporal_attempt_ledger": false,
    "bookforge_can_write_provider_completion": false,
    "bookforge_can_write_provider_queue": false,
    "bookforge_can_write_private_scheduler": false,
    "bookforge_can_write_private_session_store": false,
    "bookforge_can_write_temporal_workflow_state": false,
    "bookforge_can_write_generated_status_read_model": false,
    "bookforge_can_write_book_truth": true,
    "bookforge_can_write_manuscript_quality_refs": true,
    "bookforge_can_write_style_and_export_verdict_refs": true,
    "bookforge_can_write_memory_body": true,
    "bookforge_can_write_owner_receipt_body": true
  },
  "projection_policy": {
    "cli_or_status_may_project_policy_flags": true,
    "projection_must_not_create_second_runtime": true,
    "projection_must_not_create_attempt_ledger": true,
    "projection_must_not_wrap_temporal_or_stage_run": true,
    "projection_must_not_write_stage_attempts": true,
    "projection_must_keep_temporal_refs_refs_only": true,
    "projection_must_show_provider_completion_is_not_domain_completion": true,
    "projection_must_show_generated_surface_ready_is_not_domain_ready": true
  },
  "route_back_policy": {
    "insufficient_temporal_projection_routes_to": "one-person-lab",
    "insufficient_domain_completion_ref_routes_to": "OPL Book Forge",
    "provider_completion_without_domain_ref_routes_to": "OPL Book Forge",
    "missing_owner_or_human_decision_routes_to": "owner_or_human_gate"
  },
  "marker": "generated_by_opl_standard_domain_agent_scaffold_v1"
}
