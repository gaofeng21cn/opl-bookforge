{
  "surface_kind": "opl_temporal_stage_run_consumption_policy",
  "version": "temporal-stage-run-consumption-policy.v1",
  "state": "active_contract",
  "policy_id": "opl_bookforge_temporal_stage_run_consumption_policy",
  "domain_id": "opl-bookforge",
  "owner": "OPL Book Forge",
  "runtime_substrate_owner": "one-person-lab",
  "temporal_runtime_owner": "one-person-lab",
  "temporal_attempt_ledger_owner": "one-person-lab",
  "stage_run_owner": "one-person-lab",
  "provider_attempt_owner": "one-person-lab",
  "domain_truth_owner": "OPL Book Forge",
