        },
        {
          "dependency_id": "xelatex",
          "kind": "executable",
          "required_level": "required",
          "purpose": "XeLaTeX engine used by the bundled Chinese publication proof profile."
        },
        {
          "dependency_id": "pdftoppm",
          "kind": "executable",
          "required_level": "required",
          "purpose": "Poppler page rendering for proof page inspection and nonblank checks."
        },
        {
          "dependency_id": "quarto",
          "kind": "executable",
          "required_level": "optional",
          "purpose": "Optional future book-rendering backend for richer projects."
        },
        {
          "dependency_id": "typst",
          "kind": "executable",
          "required_level": "optional",
          "purpose": "Optional future typesetting backend for proof/export experiments."
        },
        {
          "dependency_id": "xcolor.sty",
          "kind": "latex_package",
          "required_level": "required",
          "install_target": "xcolor",
          "purpose": "Book Forge color palette."
        },
        {
          "dependency_id": "fancyhdr.sty",
          "kind": "latex_package",
          "required_level": "required",
          "install_target": "fancyhdr",
          "purpose": "Running headers and page numbers."
        },
        {
          "dependency_id": "titlesec.sty",
          "kind": "latex_package",
          "required_level": "required",
          "install_target": "titlesec",
          "purpose": "Chapter and section hierarchy."
        },
        {
          "dependency_id": "caption.sty",
          "kind": "latex_package",
          "required_level": "required",
          "install_target": "caption",
          "purpose": "Caption style and spacing."
        },
        {
          "dependency_id": "booktabs.sty",
          "kind": "latex_package",
          "required_level": "required",
          "install_target": "booktabs",
          "purpose": "Publication-grade table rules."
        },
        {
          "dependency_id": "colortbl.sty",
          "kind": "latex_package",
          "required_level": "required",
          "install_target": "colortbl",
          "purpose": "Table rule color support."
