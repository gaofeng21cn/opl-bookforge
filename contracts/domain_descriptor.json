        {
          "dependency_id": "etoolbox.sty",
          "kind": "latex_package",
          "required_level": "required",
          "install_target": "etoolbox",
          "purpose": "Environment hooks used by the proof profile."
        },
        {
          "dependency_id": "ctexbook.cls",
          "kind": "latex_package",
          "required_level": "required",
          "install_target": "ctex",
          "purpose": "Chinese book document class."
        },
        {
          "dependency_id": "titling.sty",
          "kind": "latex_package",
          "required_level": "legacy_not_required",
          "purpose": "Previously used title-page helper; no longer required by the Book Forge proof profile."
        },
        {
          "dependency_id": "tocloft.sty",
          "kind": "latex_package",
          "required_level": "legacy_not_required",
          "purpose": "Previously used TOC style helper; no longer required by the Book Forge proof profile."
        }
      ],
      "authority_boundary": {
        "can_write_domain_truth": false,
        "can_write_artifact_body": false,
        "can_authorize_publication_readiness": false,
        "can_authorize_final_export": false,
