{
  "surface_kind": "bookforge_image_generation_executor_handoff",
  "schema_version": 1,
  "owner": "opl-bookforge",
  "state": "active",
  "purpose": "Bind Book Forge project-local figure materialization to the OPL executor capability transport without creating a private Codex runner.",
  "opl_surface": {
    "owner": "OPL Runway",
    "command": "opl executor run --request <request.json> --json",
    "request_surface": "AgentExecutionRequest",
    "required_request_fields": {
      "executor_kind": "codex_cli",
      "required_capabilities": [
        "image_generation"
      ],
      "cwd": "book_project_root",
      "prompt": "bookforge_domain_prompt_with_project_local_output_target"
    },
    "required_receipt_fields": {
      "surface_kind": "opl_agent_execution_receipt",
      "requested_capabilities": [
        "image_generation"
      ],
      "activated_capabilities": [
        "image_generation"
      ],
      "exit_code": 0
    },
    "quality_debt_conditions": [
      "unknown_or_non_codex_capability_request",
      "requested_capability_not_activated",
      "executor_nonzero_exit",
      "invalid_or_missing_opl_executor_receipt"
    ],
    "transport_failure_counts_as_failed_attempt_progress": true,
    "transport_or_receipt_gap_blocks_stage_transition": false,
    "transport_or_receipt_gap_blocks_asset_ready_claim": true,
    "route_selection_owner": "codex_cli"
  },
  "bookforge_retained_boundary": {
    "responsibilities": [
      "declare_book_domain_image_prompt",
      "declare_project_local_output_target",
      "validate_final_bitmap_bytes",
      "write_project_local_figure_receipt",
      "synchronize_figure_asset_manifest",
      "retain_publication_and_delivery_authority"
    ],
    "forbidden_roles": [
      "codex_binary_discovery",
      "codex_exec_argument_builder",
      "codex_jsonl_transport_parser",
      "codex_generated_images_scanner",
      "executor_process_timeout_owner",
      "image_provider_or_credential_owner"
    ]
  },
  "authority_boundary": {
    "opl_executor_completion_counts_as_bookforge_asset_ready": false,
    "bitmap_existence_without_bookforge_validation_counts_as_asset_ready": false,
    "asset_ready_counts_as_publication_ready": false,
    "asset_ready_counts_as_final_export_ready": false,
    "asset_ready_counts_as_owner_acceptance": false,
    "opl_can_authorize_bookforge_publication_or_delivery": false,
    "opl_executor_receipt_can_select_or_reject_stage_route": false
  }
}
